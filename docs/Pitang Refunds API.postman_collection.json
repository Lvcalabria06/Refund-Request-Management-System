    {
      "name": "Auth",
      "item": [
        {
          "name": "POST login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();\r",
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));\r",
                  "pm.test(\"Returns token\", () => pm.expect(data.token).to.be.a('string'));\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "  pm.collectionVariables.set('token_employee', data.token);\r",
                  "  pm.collectionVariables.set('userId', data.user.id);\r",
                  "  console.log('Employee token saved.');\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"employee@pitang.com\",\r\n  \"password\": \"123456\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3333/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3333",
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
